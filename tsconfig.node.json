{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "shared/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "outDir": "./out/tsconfig.node.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"]
    },
    "types": ["electron-vite/node"]
  }
}
